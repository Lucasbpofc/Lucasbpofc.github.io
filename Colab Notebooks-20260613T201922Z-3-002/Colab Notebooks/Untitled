, -21.1306, -20.7539, -20.2581, -21.1200]\n","})\n","\n","fig, ax = plt.subplots(figsize=(10, 8))\n","\n","# Camada 1: Pixels de chuva (usando scatter como quadrados para simular raster)\n","sc = ax.scatter(dt_mapa['x'], dt_mapa['y'], c=dt_mapa['media_maxima'],\n","                cmap='RdYlBu_r', marker='s', s=100, alpha=0.9) # RdYlBu invertido (Azul pro Vermelho)\n","\n","# Camada 2: Contorno da Zona da Mata\n","mapa_zm.boundary.plot(ax=ax, color=\"black\", linewidth=1)\n","\n","# Camada 3: Pontos das cidades\n","ax.scatter(cidades['x'], cidades['y'], color='black', edgecolor='white', s=80, zorder=5)\n","\n","# Camada 4: Textos ajustados\n","textos = []\n","for i, row in cidades.iterrows():\n","    textos.append(ax.text(row['x'], row['y'], row['cidade'], fontsize=10, fontweight='bold',\n","                          bbox=dict(facecolor='white', alpha=0.7, edgecolor='none', boxstyle='round,pad=0.2')))\n","adjust_text(textos, ax=ax) # Organiza os rótulos\n","\n","plt.colorbar(sc, label=\"Média (mm/dia)\", shrink=0.7)\n","ax.set_title(\"Climatologia Espacial de Eventos Extremos\\nZona da Mata/MG\", fontweight='bold')\n","plt.xlabel(\"Longitude\")\n","plt.ylabel(\"Latitude\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":781},"id":"YklWN0HukikC","executionInfo":{"status":"ok","timestamp":1780091045350,"user_tz":180,"elapsed":9666,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"2a8a8e1b-17c9-4222-fa36-d1a3ba23a034"},"execution_count":37,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=========================================================\n"," PARTE 4: MAPA ESPACIAL DE MÉDIAS EXTREMAS\n","=========================================================\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x800 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Testes Estatísticos (Juiz de Fora)"],"metadata":{"id":"KiRkRaXcklYd"}},{"cell_type":"code","source":["print(\"\\n=========================================================\")\n","print(\" MODELAGEM E TESTES ESTATÍSTICOS: JUIZ DE FORA\")\n","print(\"=========================================================\\n\")\n","\n","import pymannkendall as mk\n","from statsmodels.tsa.stattools import adfuller\n","\n","# Selecionando um ponto representativo de Juiz de Fora para análise\n","# (Você pode refinar isso para a média de vários pixels urbanos depois)\n","lon_jf, lat_jf = -43.35, -21.75\n","margem = 0.05\n","serie_jf = dt_maximas_zm[(dt_maximas_zm['x'].between(lon_jf - margem, lon_jf + margem)) &\n","                         (dt_maximas_zm['y'].between(lat_jf - margem, lat_jf + margem))]\n","\n","# Se houver mais de um pixel, tiramos a média anual\n","serie_anual_jf = serie_jf.groupby('ano')['prec_maxima'].mean().reset_index()\n","chuva_array = serie_anual_jf['prec_maxima'].values\n","\n","# A. Teste de Mann-Kendall\n","mk_teste = mk.original_test(chuva_array)\n","print(\"--- TESTE DE MANN-KENDALL ---\")\n","print(f\"Tendência: {mk_teste.trend} | p-valor: {mk_teste.p:.4f}\")\n","\n","# C. Teste ADF\n","adf_teste = adfuller(chuva_array)\n","print(\"\\n--- TESTE ADF (Estacionariedade) ---\")\n","print(f\"Estatística ADF: {adf_teste[0]:.4f} | p-valor: {adf_teste[1]:.4f}\")\n","\n","# Gráfico da Série Temporal com Tendência\n","plt.figure(figsize=(10, 5))\n","sns.regplot(data=serie_anual_jf, x='ano', y='prec_maxima', ci=None,\n","            scatter_kws={\"color\": \"blue\"}, line_kws={\"color\": \"red\", \"linestyle\": \"--\"})\n","\n","plt.title(\"Precipitação Máxima vs Tempo - Juiz de Fora\", fontweight='bold')\n","plt.xlabel(\"Ano\")\n","plt.ylabel(\"Precipitação (mm)\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":667},"id":"JRbDIbqBkpIF","executionInfo":{"status":"ok","timestamp":1780091064605,"user_tz":180,"elapsed":557,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"7332098f-7c75-4d65-863a-b2bf8a09ed18"},"execution_count":38,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=========================================================\n"," MODELAGEM E TESTES ESTATÍSTICOS: JUIZ DE FORA\n","=========================================================\n","\n","--- TESTE DE MANN-KENDALL ---\n","Tendência: no trend | p-valor: 0.5150\n","\n","--- TESTE ADF (Estacionariedade) ---\n","Estatística ADF: -4.5358 | p-valor: 0.0002\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ==============================================================================\n","# SCRIPT ESPACIAL: URBANO VS RURAL PARA TODA A ZONA DA MATA (CORRIGIDO)\n","# ==============================================================================\n","import geopandas as gpd\n","import matplotlib.pyplot as plt\n","from geobr import read_meso_region\n","\n","# Caminhos dos arquivos no Colab\n","caminho_urbanas = \"/content/AU_2022_AreasUrbanizadas2019_Brasil.shp\"\n","caminho_municipios_mg = \"/content/MG_Municipios_2025.shp\"\n","\n","print(\"Lendo os shapefiles locais...\")\n","areas_urbanas = gpd.read_file(caminho_urbanas)\n","municipios_mg = gpd.read_file(caminho_municipios_mg)\n","\n","print(\"Baixando a fronteira oficial da Zona da Mata (IBGE)...\")\n","# Removido o argumento que causou o erro\n","limite_zm = read_meso_region(code_meso=3112, year=2020)\n","\n","# ==============================================================================\n","# PASSO CRÍTICO: ALINHAMENTO DE COORDENADAS (CRS)\n","# ==============================================================================\n","areas_urbanas = areas_urbanas.to_crs(epsg=4326)\n","municipios_mg = municipios_mg.to_crs(epsg=4326)\n","limite_zm = limite_zm.to_crs(epsg=4326)\n","\n","# ==============================================================================\n","# A TESOURA ESPACIAL (CLIP E OVERLAY)\n","# ==============================================================================\n","print(\"Recortando os municípios para a região da Zona da Mata...\")\n","mapa_zm = gpd.clip(municipios_mg, limite_zm)\n","\n","print(\"Separando asfalto de roça na mesorregião inteira... (Essa parte pode demorar um tiquim)\")\n","# A. Recorta as áreas urbanas do Brasil para o limite da Zona da Mata\n","mancha_urbana_zm = gpd.clip(areas_urbanas, mapa_zm)\n","\n","# B. Diferença para pegar a área rural\n","mancha_rural_zm = gpd.overlay(mapa_zm, mancha_urbana_zm, how='difference')\n","\n","# ==============================================================================\n","# VISUALIZAÇÃO DO RESULTADO\n","# ==============================================================================\n","fig, ax = plt.subplots(figsize=(14, 10))\n","\n","# Plota a área rural (verde claro)\n","mancha_rural_zm.plot(ax=ax, color='#e8f4e8', edgecolor='gray', linewidth=0.3, label='Área Rural')\n","\n","# Plota as manchas urbanas (laranja) por cima\n","mancha_urbana_zm.plot(ax=ax, color='darkorange', edgecolor='none', label='Área Urbana')\n","\n","ax.set_title(\"Delimitação: Urbano vs Rural - Mesorregião da Zona da Mata/MG\", fontweight='bold', fontsize=16)\n","plt.xlabel(\"Longitude\")\n","plt.ylabel(\"Latitude\")\n","\n","plt.show()\n","\n","print(\"Mapeamento espacial de toda a Zona da Mata concluído com sucesso!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"3BOXDdlryPvi","executionInfo":{"status":"ok","timestamp":1780093573988,"user_tz":180,"elapsed":21072,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"078c347f-9584-49f2-cabc-2c91acd0671e"},"execution_count":44,"outputs":[{"output_type":"stream","name":"stdout","text":["Lendo os shapefiles locais...\n","Baixando a fronteira oficial da Zona da Mata (IBGE)...\n","Recortando os municípios para a região da Zona da Mata...\n","Separando asfalto de roça na mesorregião inteira... (Essa parte pode demorar um tiquim)\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/geopandas/tools/overlay.py:357: UserWarning: `keep_geom_type=True` in overlay resulted in 222 dropped geometries of different geometry types than df1 has. Set `keep_geom_type=False` to retain all geometries\n","  result = _collection_extract(result, geom_type, keep_geom_type_warning)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x1000 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Mapeamento espacial de toda a Zona da Mata concluído com sucesso!\n"]}]},{"cell_type":"code","source":["Inserindo os pixels considerados em Xavier et al"],"metadata":{"id":"wmuaGFgM3RPu"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ==============================================================================\n","# SCRIPT ESPACIAL: CRIANDO A MALHA DE PIXELS REAIS (QUADRADOS)\n","# ==============================================================================\n","import geopandas as gpd\n","import matplotlib.pyplot as plt\n","from shapely.geometry import Polygon\n","\n","print(\"Extraindo as coordenadas únicas...\")\n","# O .copy() evita avisos de memória do Pandas\n","pixels_unicos = dt_maximas_zm[['x', 'y']].drop_duplicates().copy()\n","\n","print(\"Desenhando os quadrados de 0.1 x 0.1 graus para cada pixel...\")\n","# A distância do centro até a borda do pixel é 0.05 graus\n","raio = 0.05\n","\n","# Função para criar o polígono quadrado ao redor do ponto (x,y)\n","def criar_quadrado(row):\n","    x, y = row['x'], row['y']\n","    return Polygon([\n","        (x - raio, y - raio), # Canto inferior esquerdo\n","        (x + raio, y - raio), # Canto inferior direito\n","        (x + raio, y + raio), # Canto superior direito\n","        (x - raio, y + raio)  # Canto superior esquerdo\n","    ])\n","\n","# Aplica a função para criar a geometria\n","pixels_unicos['geometry'] = pixels_unicos.apply(criar_quadrado, axis=1)\n","\n","# Converte para um mapa espacial (GeoDataFrame)\n","malha_xavier = gpd.GeoDataFrame(pixels_unicos, geometry='geometry', crs=\"EPSG:4326\")\n","\n","# ==============================================================================\n","# DESENHANDO O MAPA FINAL\n","# ==============================================================================\n","print(\"Renderizando o mapa completo...\")\n","fig, ax = plt.subplots(figsize=(14, 10))\n","\n","# Camada 1: Área rural (Fundo verde claro)\n","mancha_rural_zm.plot(ax=ax, color='#e8f4e8', edgecolor='gray', linewidth=0.3, label='Área Rural')\n","\n","# Camada 2: Área urbana (Manchas laranjas)\n","mancha_urbana_zm.plot(ax=ax, color='darkorange', edgecolor='none', label='Área Urbana')\n","\n","# Camada 3: Os quadrados reais da malha BR-DWGD\n","# facecolor='none' deixa o quadrado transparente por dentro\n","malha_xavier.plot(ax=ax, facecolor='none', edgecolor='darkblue', linewidth=0.8,\n","                  alpha=0.8, label='Grade BR-DWGD (0.1°)')\n","\n","ax.set_title(\"Área de Abrangência dos Pixels (BR-DWGD) sobre o Perímetro Urbano e Rural\\nMesorregião da Zona da Mata/MG\",\n","             fontweight='bold', fontsize=16)\n","plt.xlabel(\"Longitude\")\n","plt.ylabel(\"Latitude\")\n","\n","# Organizando a legenda\n","handles, labels = ax.get_legend_handles_labels()\n","ax.legend(loc='lower right', frameon=True, facecolor='white', framealpha=0.9, fontsize=12)\n","\n","plt.show()\n","\n","print(\"Grade espacial gerada com sucesso!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":995},"id":"TIlvvDCD4fVr","executionInfo":{"status":"ok","timestamp":1780094327255,"user_tz":180,"elapsed":3801,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"4d7c59ad-0338-4b15-e5c5-26f213c46ccc"},"execution_count":46,"outputs":[{"output_type":"stream","name":"stdout","text":["Extraindo as coordenadas únicas...\n","Desenhando os quadrados de 0.1 x 0.1 graus para cada pixel...\n","Renderizando o mapa completo...\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_5987/3551466327.py:55: UserWarning: Legend does not support handles for PatchCollection instances.\n","See: https://matplotlib.org/stable/tutorials/intermediate/legend_guide.html#implementing-a-custom-legend-handler\n","  handles, labels = ax.get_legend_handles_labels()\n","/tmp/ipykernel_5987/3551466327.py:56: UserWarning: Legend does not support handles for PatchCollection instances.\n","See: https://matplotlib.org/stable/tutorials/intermediate/legend_guide.html#implementing-a-custom-legend-handler\n","  ax.legend(loc='lower right', frameon=True, facecolor='white', framealpha=0.9, fontsize=12)\n","/tmp/ipykernel_5987/3551466327.py:56: UserWarning: No artists with labels found to put in legend.  Note that artists whose label start with an underscore are ignored when legend() is called with no argument.\n","  ax.legend(loc='lower right', frameon=True, facecolor='white', framealpha=0.9, fontsize=12)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x1000 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Grade espacial gerada com sucesso!\n"]}]},{"cell_type":"markdown","source":["Verificando a existencia de tendencia e ou estacionariedade"],"metadata":{"id":"hIwMj1D45tXv"}},{"cell_type":"code","source":["# ==============================================================================\n","# SCRIPT ESPACIAL-ESTATÍSTICO: TESTES DE TENDÊNCIA E ESTACIONARIEDADE\n","# ==============================================================================\n","import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import matplotlib.patches as mpatches\n","import geopandas as gpd\n","import pymannkendall as mk\n","from statsmodels.tsa.stattools import adfuller\n","\n","print(\"Iniciando a varredura estatística pixel a pixel. Isso pode levar alguns segundos...\\n\")\n","\n","# 1. Lista para guardar os resultados de cada pixel\n","resultados_testes = []\n","\n","# 2. Agrupando a base de dados pelas coordenadas (x, y)\n","grupos_pixels = dt_maximas_zm.groupby(['x', 'y'])\n","\n","for (x, y), grupo in grupos_pixels:\n","    # Ordena a série temporal do pixel cronologicamente\n","    serie = grupo.sort_values('ano')['prec_maxima'].values\n","\n","    # Prevenção: só roda o teste se a série tiver um tamanho razoável\n","    if len(serie) < 30:\n","        continue\n","\n","    # --------------------------------------------------------------------------\n","    # A. Teste de Mann-Kendall (Tendência)\n","    # H0: Não há tendência | H1: Há tendência\n","    # --------------------------------------------------------------------------\n","    mk_teste = mk.original_test(serie)\n","    p_mk = mk_teste.p\n","    # Se p < 0.05, rejeita H0 (Tem tendência -> Vermelho). Senão (Azul)\n","    cor_tendencia = 'red' if p_mk < 0.05 else 'blue'\n","\n","    # --------------------------------------------------------------------------\n","    # B. Teste ADF (Estacionariedade)\n","    # H0: Tem raiz unitária (Não é estacionária) | H1: É estacionária\n","    # --------------------------------------------------------------------------\n","    # O try/except ignora avisos em séries perfeitamente constantes (raro em chuvas)\n","    try:\n","        adf_teste = adfuller(serie)\n","        p_adf = adf_teste[1]\n","    except:\n","        p_adf = 1.0 # Em caso de erro numérico, assume não estacionária\n","\n","    # Se p < 0.05, rejeita H0 (É estacionária -> Verde). Senão (Vermelho)\n","    cor_estacionaria = 'green' if p_adf < 0.05 else 'red'\n","\n","    # Guarda o diagnóstico do pixel\n","    resultados_testes.append({\n","        'x': x, 'y': y,\n","        'p_mk': p_mk, 'cor_tendencia': cor_tendencia,\n","        'p_adf': p_adf, 'cor_estacionaria': cor_estacionaria\n","    })\n","\n","# 3. Transforma os resultados em um DataFrame\n","df_testes = pd.DataFrame(resultados_testes)\n","\n","print(f\"Testes concluídos com sucesso para {len(df_testes)} pixels!\\n\")\n","\n","# ==============================================================================\n","# CRUZAMENTO DOS RESULTADOS COM A GEOMETRIA (MALHA XAVIER)\n","# ==============================================================================\n","# Fazendo um merge (PROCV) das cores que calculamos com os quadrados do mapa\n","# Assumindo que o GeoDataFrame 'malha_xavier' já está carregado na memória\n","malha_com_testes = malha_xavier.merge(df_testes, on=['x', 'y'])\n","\n","# ==============================================================================\n","# DESENHANDO OS MAPAS (VISUALIZAÇÃO LADO A LADO)\n","# ==============================================================================\n","fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(20, 10))\n","\n","# --- MAPA 1: TENDÊNCIA (MANN-KENDALL) ---\n","# Desenha o fundo da Zona da Mata\n","limite_zm.plot(ax=ax1, color='#f0f0f0', edgecolor='black', linewidth=0.8)\n","\n","# Desenha os quadrados pintados com as cores do teste\n","malha_com_testes.plot(ax=ax1, color=malha_com_testes['cor_tendencia'],\n","                      edgecolor='white', linewidth=0.2, alpha=0.8)\n","\n","ax1.set_title(\"Teste de Mann-Kendall (Tendência)\\nPrecipitações Máximas Anuais\", fontweight='bold', fontsize=14)\n","ax1.set_xlabel(\"Longitude\")\n","ax1.set_ylabel(\"Latitude\")\n","\n","# Legenda customizada Mapa 1\n","legenda_mk = [\n","    mpatches.Patch(color='red', label='Com Tendência (p < 0.05)'),\n","    mpatches.Patch(color='blue', label='Sem Tendência (p $\\geq$ 0.05)')\n","]\n","ax1.legend(handles=legenda_mk, loc='lower right', framealpha=0.9)\n","\n","\n","# --- MAPA 2: ESTACIONARIEDADE (ADF) ---\n","# Desenha o fundo da Zona da Mata\n","limite_zm.plot(ax=ax2, color='#f0f0f0', edgecolor='black', linewidth=0.8)\n","\n","# Desenha os quadrados pintados com as cores do teste\n","malha_com_testes.plot(ax=ax2, color=malha_com_testes['cor_estacionaria'],\n","                      edgecolor='white', linewidth=0.2, alpha=0.8)\n","\n","ax2.set_title(\"Teste ADF (Estacionariedade)\\nPrecipitações Máximas Anuais\", fontweight='bold', fontsize=14)\n","ax2.set_xlabel(\"Longitude\")\n","\n","# Legenda customizada Mapa 2\n","legenda_adf = [\n","    mpatches.Patch(color='green', label='Série Estacionária (p < 0.05)'),\n","    mpatches.Patch(color='red', label='Não Estacionária (p $\\geq$ 0.05)')\n","]\n","ax2.legend(handles=legenda_adf, loc='lower right', framealpha=0.9)\n","\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":631},"id":"jtzIFUCy8T6M","executionInfo":{"status":"ok","timestamp":1780095216266,"user_tz":180,"elapsed":4831,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"77a95dac-db98-4bc5-f12f-e7fcfe7d79a2"},"execution_count":50,"outputs":[{"output_type":"stream","name":"stderr","text":["<>:90: SyntaxWarning: invalid escape sequence '\\g'\n","<>:109: SyntaxWarning: invalid escape sequence '\\g'\n","<>:90: SyntaxWarning: invalid escape sequence '\\g'\n","<>:109: SyntaxWarning: invalid escape sequence '\\g'\n","/tmp/ipykernel_5987/3675961210.py:90: SyntaxWarning: invalid escape sequence '\\g'\n","  mpatches.Patch(color='blue', label='Sem Tendência (p $\\geq$ 0.05)')\n","/tmp/ipykernel_5987/3675961210.py:109: SyntaxWarning: invalid escape sequence '\\g'\n","  mpatches.Patch(color='red', label='Não Estacionária (p $\\geq$ 0.05)')\n"]},{"output_type":"stream","name":"stdout","text":["Iniciando a varredura estatística pixel a pixel. Isso pode levar alguns segundos...\n","\n","Testes concluídos com sucesso para 374 pixels!\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 2000x1000 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Agora ajustamos GEV estacionária para as séries que não indicaram a presença de tendencia e não estacionária para as séries que apresentaram alguma tendencia. Fora ajustados 3 modelos; M1 com variação no Mu, M2 com variação no Sigma e M3 com variação em MU e Sigma ao mesmo tempo."],"metadata":{"id":"wWSbtwCa-Y4j"}},{"cell_type":"code","source":["# ==============================================================================\n","# MODELAGEM COMPETITIVA GEV: ESTACIONÁRIA VS NÃO-ESTACIONÁRIA (TRV)\n","# ==============================================================================\n","import numpy as np\n","import pandas as pd\n","import geopandas as gpd\n","from scipy.optimize import minimize\n","from scipy.stats import genextreme, chi2\n","\n","# Garantindo que temos o vetor de tempo normalizado (t de 1 a N)\n","# Isso ajuda na convergência da otimização numérica\n","dt_maximas_zm['t'] = dt_maximas_zm['ano'] - dt_maximas_zm['ano'].min() + 1\n","\n","# ==============================================================================\n","# FUNÇÕES DE LOG-VEROSSIMILHANÇA NEGATIVA (Para o otimizador numérico)\n","# ==============================================================================\n","\n","# Modelo Estacionário (Padrão: mu, sigma, xi constantes)\n","def nll_estacionario(params, x_data):\n","    mu, sigma, xi = params\n","    if sigma <= 0: return 1e10\n","    # Scipy usa c = -xi\n","    return -np.sum(genextreme.logpdf(x_data, -xi, loc=mu, scale=sigma))\n","\n","# Modelo 1: Mu varia com o tempo (mu_t = mu0 + mu1 * t)\n","def nll_modelo1(params, x_data, t_data):\n","    mu0, mu1, sigma, xi = params\n","    if sigma <= 0: return 1e10\n","    mu_t = mu0 + mu1 * t_data\n","    return -np.sum(genextreme.logpdf(x_data, -xi, loc=mu_t, scale=sigma))\n","\n","# Modelo 2: Sigma varia com o tempo (usando link log para garantir escala > 0)\n","def nll_modelo2(params, x_data, t_data):\n","    mu, sigma0, sigma1, xi = params\n","    sigma_t = np.exp(sigma0 + sigma1 * t_data)\n","    return -np.sum(genextreme.logpdf(x_data, -xi, loc=mu, scale=sigma_t))\n","\n","# Modelo 3: Ambos Mu e Sigma variam com o tempo\n","def nll_modelo3(params, x_data, t_data):\n","    mu0, mu1, sigma0, sigma1, xi = params\n","    mu_t = mu0 + mu1 * t_data\n","    sigma_t = np.exp(sigma0 + sigma1 * t_data)\n","    return -np.sum(genextreme.logpdf(x_data, -xi, loc=mu_t, scale=sigma_t))\n","\n","# ==============================================================================\n","# LOOP DE MODELAGEM PIXEL A PIXEL\n","# ==============================================================================\n","print(\"Iniciando a competição de modelos via TRV para toda a Zona da Mata...\")\n","\n","resultados_mapeamento = []\n","grupos = dt_maximas_zm.groupby(['x', 'y'])\n","\n","# df_testes foi criado na etapa anterior (contém a coluna 'cor_tendencia')\n","# Se você não executou a célula anterior neste momento, o código abaixo faz a checagem direta\n","for (x, y), grupo in grupos:\n","    grupo_ordenado = grupo.sort_values('ano')\n","    v_chuva = grupo_ordenado['prec_maxima'].values\n","    v_tempo = grupo_ordenado['t'].values\n","    n = len(v_chuva)\n","\n","    # Puxa o diagnóstico do Mann-Kendall para este pixel\n","    # Se não houver tendência prévia, fixa no Estacionário para poupar tempo\n","    tem_tendencia = df_testes[(df_testes['x'] == x) & (df_testes['y'] == y)]['cor_tendencia'].values[0] == 'red'\n","\n","    # Chutes iniciais baseados nos momentos amostrais\n","    mu_init = np.mean(v_chuva)\n","    sigma_init = np.std(v_chuva)\n","    xi_init = 0.1\n","\n","    # 1. Ajuste do Modelo Estacionário (Obrigatório para todos)\n","    res_est = minimize(nll_estacionario, [mu_init, sigma_init, xi_init], args=(v_chuva,), method='Nelder-Mead')\n","    loglik_est = -res_est.fun\n","\n","    if not tem_tendencia:\n","        # Se não tem tendência, o vencedor é o Estacionário por W.O.\n","        resultados_mapeamento.append({\n","            'x': x, 'y': y, 'modelo_vencedor': 'Estacionario',\n","            'mu0': res_est.x[0], 'mu1': 0.0, 'sigma0': np.log(res_est.x[1]), 'sigma1': 0.0, 'xi': res_est.x[2]\n","        })\n","        continue\n","\n","    # 2. Ajuste do Modelo 1 (Variação em Mu)\n","    res_m1 = minimize(nll_modelo1, [mu_init, 0.0, sigma_init, xi_init], args=(v_chuva, v_tempo), method='Nelder-Mead')\n","    loglik_m1 = -res_m1.fun\n","\n","    # 3. Ajuste do Modelo 2 (Variação em Sigma)\n","    res_m2 = minimize(nll_modelo2, [mu_init, np.log(sigma_init), 0.0, xi_init], args=(v_chuva, v_tempo), method='Nelder-Mead')\n","    loglik_m2 = -res_m2.fun\n","\n","    # 4. Ajuste do Modelo 3 (Variação em Mu e Sigma)\n","    res_m3 = minimize(nll_modelo3, [mu_init, 0.0, np.log(sigma_init), 0.0, xi_init], args=(v_chuva, v_tempo), method='Nelder-Mead')\n","    loglik_m3 = -res_m3.fun\n","\n","    # ==========================================================================\n","    # APLICANDO O TESTE DA RAZÃO DE VEROSSIMILHANÇA (TRV) - Alfa = 0.05\n","    # ==========================================================================\n","    alfa = 0.05\n","    val_critico_1gl = chi2.ppf(1 - alfa, df=1)\n","    val_critico_2gl = chi2.ppf(1 - alfa, df=2)\n","\n","    # Testando os modelos de 1 parâmetro extra contra o estacionário\n","    trv_m1 = 2 * (loglik_m1 - loglik_est)\n","    trv_m2 = 2 * (loglik_m2 - loglik_est)\n","\n","    m1_rejeita_h0 = trv_m1 > val_critico_1gl\n","    m2_rejeita_h0 = trv_m2 > val_critico_1gl\n","\n","    # Decisão hierárquica\n","    modelo_vencedor = 'Estacionario'\n","    params_finais = res_est.x\n","    mu0, mu1, sigma0, sigma1, xi = params_finais[0], 0.0, np.log(params_finais[1]), 0.0, params_finais[2]\n","\n","    # Se M1 ou M2 ganharam do Estacionário, o jogo muda\n","    if m1_rejeita_h0 or m2_rejeita_h0:\n","        if loglik_m1 > loglik_m2:\n","            modelo_vencedor = 'Modelo 1 (Mu)'\n","            mu0, mu1, sigma0, sigma1, xi = res_m1.x[0], res_m1.x[1], np.log(res_m1.x[2]), 0.0, res_m1.x[3]\n","            loglik_melhor_1gl = loglik_m1\n","        else:\n","            modelo_vencedor = 'Modelo 2 (Sigma)'\n","            mu0, mu1, sigma0, sigma1, xi = res_m2.x[0], 0.0, res_m2.x[1], res_m2.x[2], res_m2.x[3]\n","            loglik_melhor_1gl = loglik_m2\n","\n","        # Agora testa se o Modelo 3 (2 parâmetros extras) ganha do melhor de 1 parâmetro extra\n","        trv_m3 = 2 * (loglik_m3 - loglik_melhor_1gl)\n","        if trv_m3 > val_critico_1gl: # Diferença de M3 para M1 ou M2 é de 1 grau de liberdade\n","            modelo_vencedor = 'Modelo 3 (Mu e Sigma)'\n","            mu0, mu1, sigma0, sigma1, xi = res_m3.x[0], res_m3.x[1], res_m3.x[2], res_m3.x[3], res_m3.x[4]\n","\n","    resultados_mapeamento.append({\n","        'x': x, 'y': y, 'modelo_vencedor': 'Estacionario' if modelo_vencedor == 'Estacionario' else modelo_vencedor,\n","        'mu0': mu0, 'mu1': mu1, 'sigma0': sigma0, 'sigma1': sigma1, 'xi': xi\n","    })\n","\n","df_gev_final = pd.DataFrame(resultados_mapeamento)\n","print(\"\\nModelagem competitiva concluída para todos os píxels!\")\n","print(df_gev_final['modelo_vencedor'].value_counts())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ToAR2JNv-uNv","executionInfo":{"status":"ok","timestamp":1780095978173,"user_tz":180,"elapsed":127268,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"d0f7e8bc-fe85-41b8-f414-f0dab4fdce20"},"execution_count":51,"outputs":[{"output_type":"stream","name":"stdout","text":["Iniciando a competição de modelos via TRV para toda a Zona da Mata...\n","\n","Modelagem competitiva concluída para todos os píxels!\n","modelo_vencedor\n","Estacionario             229\n","Modelo 1 (Mu)            117\n","Modelo 3 (Mu e Sigma)     27\n","Modelo 2 (Sigma)           1\n","Name: count, dtype: int64\n"]}]},{"cell_type":"markdown","source":["O gráfico a seguir indica qual modelo foi superior em cada região"],"metadata":{"id":"yDnVofoO_AnI"}},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n",