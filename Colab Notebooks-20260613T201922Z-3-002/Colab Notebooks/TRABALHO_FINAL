RdBu_r\",\n","    vmax=1.0,\n","    vmin=-1.0,\n","    center=0,\n","    annot=True,  # Mostra os valores dos coeficientes dentro dos quadrados\n","    fmt=\".2f\",  # Duas casas decimais\n","    linewidths=0.5,\n","    cbar_kws={\"shrink\": 0.8, \"label\": \"Coeficiente de Correlação de Pearson\"},\n","    square=True,\n",")\n","\n","plt.title(\n","    \"Matriz de Correlação de Pearson\\nEntendendo as relações antes da seleção de variáveis\",\n","    fontsize=16,\n","    fontweight=\"bold\",\n","    pad=20,\n",")\n","plt.xticks(rotation=45, ha=\"right\", fontsize=11)\n","plt.yticks(fontsize=11)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":642},"id":"vcBCHNbUhQUl","executionInfo":{"status":"ok","timestamp":1780926977248,"user_tz":180,"elapsed":1141,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"48073803-0f93-49db-a7cf-93e6d691d927"},"execution_count":14,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x1400 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import statsmodels.api as sm\n","import pandas as pd\n","\n","# 1. Definindo a variável resposta (Y)\n","y = df['TCH.x']\n","\n","# 2. Selecionando os 4 preditores estratégicos (X)\n","preditores_selecionados = ['NC', 'ALTURA', 'NGRDI', 'pH']\n","X = df[preditores_selecionados]\n","\n","# 3. Adicionando o intercepto (beta_0) para o cálculo correto\n","X = sm.add_constant(X)\n","\n","# 4. Ajustando o modelo linear\n","modelo_parcimonioso = sm.OLS(y, X).fit()\n","\n","# 5. Exibindo o resumo estatístico completo\n","print(modelo_parcimonioso.summary())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"mxiHqbeheO-I","executionInfo":{"status":"ok","timestamp":1780927163051,"user_tz":180,"elapsed":29,"user":{"displayName":"lucas pereira belo","userId":"16262025946459305793"}},"outputId":"d15c871e-3267-46db-cdf6-45932f060aef"},"execution_co